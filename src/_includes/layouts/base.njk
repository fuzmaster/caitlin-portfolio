<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="index,follow" />
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="{{ site.siteUrl }}{{ canonicalPath }}" />
  <meta property="og:image" content="{{ site.siteUrl }}/assets/images/avatar.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="{{ site.siteUrl }}/assets/images/avatar.png" />
  <link rel="canonical" href="{{ site.siteUrl }}{{ canonicalPath }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="stylesheet" href="{{ 'css/styles.css' | assetUrl }}" />
  {% if structuredData %}
  <script type="application/ld+json">{{ structuredData | jsonStringify | safe }}</script>
  {% endif %}
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  {% include "partials/site-header.njk" %}
  <main id="main-content">
    {{ content | safe }}
  </main>
  {% include "partials/site-footer.njk" %}
  <script type="module" src="{{ 'js/main.js' | assetUrl }}"></script>
  {% if pageScript %}
  <script type="module" src="{{ pageScript | assetUrl }}"></script>
  {% endif %}
</body>
</html>
