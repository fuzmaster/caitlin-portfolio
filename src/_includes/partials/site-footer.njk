<footer class="site-footer">
  <div class="l-shell site-footer__inner">
    <div>
      <p class="site-footer__brand">{{ site.name }}</p>
      <p>{{ site.tagline | capitalize }}.</p>
    </div>
    <div>
      <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      <p><a href="tel:+19785550146">{{ site.phone }}</a></p>
      <p>{{ site.location }} - Available for remote work nationwide.</p>
    </div>
    <div>
      <p>{{ site.footerPrivacy }}</p>
      <p>&copy; {{ site.year }} {{ site.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>
