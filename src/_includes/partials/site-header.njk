<header class="site-header">
  <div class="l-shell site-header__inner">
    <a class="site-logo" href="/">{{ site.name }}</a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Open navigation menu">
      <span class="sr-only">Toggle main menu</span>
      <span class="nav-toggle__bar" aria-hidden="true"></span>
    </button>
    <nav id="primary-nav" class="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        {% for item in site.navigation %}
          {% set isActive = page.url == item.url %}
          <li>
            <a href="{{ item.url }}" {% if isActive %}aria-current="page"{% endif %}>{{ item.label }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
