---
layout: layouts/base.njk
title: Contact | Caitlin Britten
description: Schedule a consultation with Caitlin Britten for remote admin support, scheduling operations, and client communication services.
canonicalPath: /contact/
ogType: website
structuredData:
  '@context': https://schema.org
  '@type': ContactPage
  name: Contact Caitlin Britten
---
<section class="section" aria-labelledby="contact-heading">
  <div class="l-shell split-layout split-layout--contact">
    <div>
      <p class="kicker">Contact</p>
      <h1 id="contact-heading">Let's talk about your studio workflow</h1>
      <p class="lede">Share your biggest operations bottleneck and I will propose a practical support plan.</p>
      <ul class="contact-list" role="list">
        <li><strong>Email:</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><strong>Phone:</strong> <a href="tel:+19785550146">{{ site.phone }}</a></li>
        <li><strong>LinkedIn:</strong> <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer">View profile</a></li>
      </ul>
    </div>

    <form class="contact-form" action="https://formspree.io/f/mjgaeykk" method="POST" aria-label="Contact form">
      <div class="field-group">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field-group">
        <label for="email">Email address</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field-group">
        <label for="company">Company</label>
        <input id="company" name="company" type="text" autocomplete="organization" />
      </div>
      <div class="field-group">
        <label for="message">Project details</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>
      <p class="privacy-note">Privacy notice: {{ site.footerPrivacy }}</p>
      <button class="btn btn--primary" type="submit">Send message</button>
    </form>
  </div>
</section>
